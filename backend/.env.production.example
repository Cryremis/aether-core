APP_NAME=AetherCore Backend
APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=8100
APP_PUBLIC_BASE_URL=https://aethercore-api.example.com
APP_DEBUG=false
MANAGE_BACKEND_HOST=127.0.0.1
MANAGE_BACKEND_PORT=8100
MANAGE_FRONTEND_HOST=127.0.0.1
MANAGE_FRONTEND_PORT=5178
MANAGE_FRONTEND_PUBLIC_BASE_URL=https://aethercore.example.com

CORS_ORIGINS=["https://aethercore.example.com"]

LLM_PROVIDER=openai_compatible
LLM_PROVIDER_NAME=volcengine
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=replace-with-your-model
LLM_API_KEY=replace-with-your-api-key
LLM_TIMEOUT_SECONDS=180
LLM_MAX_TOKENS=4000
LLM_NETWORK_ENABLED=true
LLM_NETWORK_ALLOWED_DOMAINS=[]
LLM_NETWORK_BLOCKED_DOMAINS=[]
LLM_NETWORK_MAX_SEARCH_RESULTS=8
LLM_NETWORK_FETCH_TIMEOUT_SECONDS=30
LLM_NETWORK_FETCH_MAX_BYTES=2097152
LLM_NETWORK_USER_AGENT=AetherCore/1.0

AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=10080
AUTH_EMBED_TOKEN_EXPIRE_MINUTES=1440
AUTH_SYSTEM_ADMIN_USERNAME=admin
AUTH_SYSTEM_ADMIN_PASSWORD=replace-with-a-strong-password
AUTH_DEBUG_USERNAME=debug
AUTH_DEBUG_PASSWORD=replace-with-a-strong-password
AUTH_OAUTH_PROVIDERS=corp-sso
AUTH_OAUTH_CORP_SSO_DISPLAY_NAME=Company SSO
AUTH_OAUTH_CORP_SSO_CLIENT_ID=
AUTH_OAUTH_CORP_SSO_CLIENT_SECRET=
AUTH_OAUTH_CORP_SSO_AUTHORIZE_URL=
AUTH_OAUTH_CORP_SSO_TOKEN_URL=
AUTH_OAUTH_CORP_SSO_USERINFO_URL=
AUTH_OAUTH_CORP_SSO_SCOPE=base.profile
AUTH_OAUTH_CORP_SSO_TOKEN_REQUEST_FORMAT=json
AUTH_OAUTH_CORP_SSO_USERINFO_REQUEST_FORMAT=json
AUTH_OAUTH_CORP_SSO_USER_ID_FIELDS=uuid
AUTH_OAUTH_CORP_SSO_USER_NAME_FIELDS=displayNameCn,displayName
AUTH_OAUTH_CORP_SSO_USER_EMAIL_FIELDS=email
AUTH_OAUTH_CORP_SSO_WHITELIST_MATCH_FIELDS=uuid,uid,employeeNumber

AGENT_MAX_TURNS=0
# AGENT_MAX_RUNTIME_SECONDS=1800
AGENT_MAX_STALL_ROUNDS=0

STORAGE_ROOT=/opt/aethercore/shared/storage
SESSIONS_DIR_NAME=sessions
BUILT_IN_SKILLS_DIR=storage/built_in_skills
METADATA_DB_NAME=aethercore.db

SANDBOX_EXECUTOR=docker
SANDBOX_FAIL_CLOSED=true
SANDBOX_LOCAL_ENABLED=false
SANDBOX_SHELL=bash
SANDBOX_COMMAND_TIMEOUT_SECONDS=120
# SANDBOX_COMMAND_MAX_TIMEOUT_SECONDS=1800
SANDBOX_OUTPUT_CHAR_LIMIT=12000
SANDBOX_FILE_READ_LIMIT_BYTES=131072
SANDBOX_ALLOW_NETWORK=true
SANDBOX_ENV_WHITELIST=["PATH"]
SANDBOX_BLOCKED_COMMAND_KEYWORDS=["curl ","wget ","invoke-webrequest","irm ","scp ","ssh ","ftp ","telnet ","docker ","kubectl ","shutdown","restart-computer","stop-computer","format ","format-volume","mount ","dism "]
SANDBOX_DOCKER_COMMAND=docker
SANDBOX_DOCKER_IMAGE=aethercore-sandbox:latest
SANDBOX_DOCKER_WORKSPACE_MOUNT=/workspace
SANDBOX_DOCKER_WORK_DIR=/workspace/work
SANDBOX_DOCKER_INPUT_DIR=/workspace/input
SANDBOX_DOCKER_OUTPUT_DIR=/workspace/output
SANDBOX_DOCKER_SKILLS_DIR=/workspace/skills
SANDBOX_DOCKER_LOGS_DIR=/workspace/logs
SANDBOX_DOCKER_USER=sandbox
SANDBOX_DOCKER_NETWORK_MODE=bridge
SANDBOX_DOCKER_AUTO_DNS_FROM_HOST=true
SANDBOX_DOCKER_DNS_SERVERS=[]
SANDBOX_DOCKER_ENV_PASSTHROUGH=["HTTP_PROXY","HTTPS_PROXY","NO_PROXY","http_proxy","https_proxy","no_proxy","ALL_PROXY","all_proxy","PIP_INDEX_URL","PIP_EXTRA_INDEX_URL","PIP_TRUSTED_HOST"]
SANDBOX_DOCKER_MEMORY=1g
SANDBOX_DOCKER_CPUS=1.0
SANDBOX_DOCKER_PIDS_LIMIT=128
SANDBOX_DOCKER_READ_ONLY_ROOTFS=false
SANDBOX_DOCKER_TMPFS=["/tmp:size=256m","/var/tmp:size=64m"]
